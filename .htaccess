<IfModule mod_rewrite.c>
    RewriteEngine On

    # -------------------------------------------------------------
    # 🔒 Paksa HTTPS hanya kalau bukan di localhost
    # -------------------------------------------------------------
    RewriteCond %{HTTP_HOST} !^localhost [NC]
    RewriteCond %{HTTPS} !=on
    RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # -------------------------------------------------------------
    # 🚫 Blok akses langsung ke folder sistem (system / application)
    # -------------------------------------------------------------
    RewriteCond %{REQUEST_URI} ^(system|application) [NC]
    RewriteRule ^(.*)$ /index.php?/$1 [L]

    # -------------------------------------------------------------
    # ⚙️ Izinkan akses langsung ke folder aset publik
    # -------------------------------------------------------------
    RewriteCond %{REQUEST_URI} ^(assets|uploads|files|images|css|js) [NC]
    RewriteCond %{REQUEST_FILENAME} -f
    RewriteRule ^ - [L]

    # -------------------------------------------------------------
    # 🚀 Hilangkan index.php dari URL (CodeIgniter, Laravel, dll)
    # -------------------------------------------------------------
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.*)$ index.php?/$1 [L]
</IfModule>

# -------------------------------------------------------------
# 🧰 Header keamanan dasar (anti XSS, clickjacking, MIME sniffing)
# -------------------------------------------------------------
<IfModule mod_headers.c>
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set X-Content-Type-Options "nosniff"
</IfModule>

# -------------------------------------------------------------
# 🚫 Lindungi file sensitif agar tidak bisa diakses langsung
# -------------------------------------------------------------
<FilesMatch "(^\.|composer\.json|composer\.lock|\.env|README|LICENSE|phpunit\.xml|package\.json|webpack\.mix\.js)">
    Require all denied
</FilesMatch>

# -------------------------------------------------------------
# ✅ Optional: nonaktifkan directory listing (biar tidak kelihatan isi folder)
# -------------------------------------------------------------
Options -Indexes

# -------------------------------------------------------------
# ✅ Optional: tambahkan cache control dasar untuk file statis
# -------------------------------------------------------------
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpg "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType text/javascript "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType application/x-javascript "access plus 1 month"
    ExpiresByType image/x-icon "access plus 1 year"
</IfModule>
